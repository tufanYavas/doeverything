{
  "name": "@doeverything/mcp-bridge",
  "version": "1.0.1",
  "description": "doeverything MCP bridge — stdio adapter that connects any MCP client to the Chrome extension via a local WebSocket server",
  "type": "module",
  "private": false,
  "license": "MIT",
  "bin": {
    "doeverything-mcp": "dist/cli.mjs"
  },
  "files": [
    "dist/**"
  ],
  "scripts": {
    "clean:bundle": "rimraf dist",
    "clean:node_modules": "pnpx rimraf node_modules",
    "clean:turbo": "rimraf .turbo",
    "clean": "pnpm clean:bundle && pnpm clean:node_modules && pnpm clean:turbo",
    "build": "tsc -b",
    "ready": "tsc -b",
    "lint": "eslint .",
    "lint:fix": "pnpm lint --fix",
    "format": "prettier . --write --ignore-path ../../.prettierignore",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@doeverything/tsconfig": "workspace:*",
    "@types/ws": "^8.18.1"
  },
  "engines": {
    "node": ">=18.3.0"
  }
}
