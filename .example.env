# doeverything — environment variables
# Copy this file to `.env` and fill in the values you need.

# ---------------------------------------------------------------------------
# MCP relay
# ---------------------------------------------------------------------------
# WebSocket relay server (Cloudflare Worker + Durable Object).
# Deploy `relay/` to your Cloudflare account, then set this URL.
DOE_RELAY_BASE_URL=https://relay.doeverythi.ng

# ---------------------------------------------------------------------------
# Feature flags
# ---------------------------------------------------------------------------
DOE_LOCAL_FEATURE_FLAGS=true
DOE_FEATURE_FLAGS_URL=

# ---------------------------------------------------------------------------
# Analytics & error tracking (optional)
# ---------------------------------------------------------------------------
DOE_DISABLE_ANALYTICS=true
DOE_SEGMENT_WRITE_KEY=
DOE_SENTRY_DSN=
