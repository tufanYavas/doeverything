{
  "name": "@doeverything/chrome-extension",
  "version": "1.0.0",
  "description": "doeverything — chrome extension core settings",
  "type": "module",
  "private": true,
  "sideEffects": false,
  "scripts": {
    "clean:node_modules": "pnpx rimraf node_modules",
    "clean:turbo": "rimraf .turbo",
    "clean": "pnpm clean:turbo && pnpm clean:node_modules",
    "ready": "tsc -b pre-build.tsconfig.json",
    "build": "vite build",
    "dev": "vite build --watch --mode development",
    "test": "vitest run",
    "lint": "eslint .",
    "lint:fix": "pnpm lint --fix",
    "prettier": "prettier . --write --ignore-path ../.prettierignore",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@doeverything/env": "workspace:*",
    "@doeverything/llm-providers": "workspace:*",
    "@doeverything/shared": "workspace:*",
    "@doeverything/storage": "workspace:*",
    "ai": "^6.0.0",
"webextension-polyfill": "^0.12.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@doeverything/dev-utils": "workspace:*",
    "@doeverything/hmr": "workspace:*",
    "@doeverything/tsconfig": "workspace:*",
    "@doeverything/vite-config": "workspace:*",
    "@laynezh/vite-plugin-lib-assets": "^1.1.0",
"magic-string": "^0.30.17",
    "ts-loader": "^9.5.2"
  }
}
